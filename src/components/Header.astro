---
import { Image } from 'astro:assets';
import { site } from '../config';
import logo from '../assets/images/logo.png';
const base = import.meta.env.BASE_URL;
---

<header>
  <!-- utility bar -->
  <div data-r="util">
    <span>Benicia, California &middot; Founded 1847</span>
    <span>
      <a href={site.phone_tel} class="link-quiet">{site.phone_display}</a>
      &nbsp;&middot;&nbsp;
      <a href={site.instagram_url} target="_blank" rel="noopener" class="link-quiet">Instagram</a>
      &nbsp;&middot;&nbsp;
      <a href={site.facebook_url} target="_blank" rel="noopener" class="link-quiet">Facebook</a>
      &nbsp;&middot;&nbsp;
      <a href={site.youtube_url} target="_blank" rel="noopener" class="link-quiet">YouTube</a>
    </span>
  </div>

  <!-- masthead -->
  <div class="container container-pad container-1180 masthead">
    <a href={base} class="masthead-logo-link">
      <Image src={logo} alt="Benicians Adopting Benicia seal" width={132} height={132} format="webp" loading="eager" />
    </a>
    <div class="masthead-rule-row">
      <span class="masthead-rule"></span>
      <span class="masthead-label">Est. by the Community</span>
      <span class="masthead-rule"></span>
    </div>
    <a href={base} class="masthead-wordmark-link">
      <h1 data-r="wordmark">{site.title}</h1>
    </a>
    <div data-r="subtitle">A Community Beautification &amp; Civic Society</div>
  </div>
</header>

<!-- nav (sticky independently of the masthead) -->
<nav data-r="nav" data-base={base}>
  <a href={base} class="nav-link">Home</a>
  <a href={`${base}about/`} class="nav-link">About</a>
  <a href={`${base}events/`} class="nav-link">Events</a>
  <a href={`${base}get-involved/`} class="nav-link">Get Involved</a>
  <a href={`${base}newsletter/`} class="nav-link">Newsletter</a>
  <a href={site.donate_url} target="_blank" rel="noopener" class="nav-donate">Donate</a>
</nav>
<script is:inline>
  const nav = document.querySelector('nav[data-base]');
  const base = nav.dataset.base;
  const path = window.location.pathname;
  document.querySelectorAll('.nav-link').forEach(a => {
    const href = a.getAttribute('href');
    const isHome = href === base || href === base.replace(/\/$/, '');
    const active = isHome
      ? (path === href || path === href + '/')
      : (path === href || path === href + '/' || path.startsWith(href + '/'));
    if (active) a.setAttribute('aria-current', 'page');
  });
</script>
