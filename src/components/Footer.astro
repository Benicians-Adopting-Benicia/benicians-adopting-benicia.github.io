---
import { site } from '../config';
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer style="background:#1e2a4f; color:#cdd3e4; margin-top:auto;">
  <div data-r="g-foot" style="max-width:1180px; margin:0 auto; padding:52px 40px; display:grid; grid-template-columns:1.4fr 1fr 1fr; gap:48px;">
    <div>
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
        <img src={`${base}assets/images/logo.png`} alt="" style="width:52px; height:52px; border-radius:50%;">
        <span style="font-family:'Newsreader',serif; font-size:19px; font-weight:600; color:#fff;">{site.title}</span>
      </div>
      <p style="font-size:14px; line-height:1.6; color:#aab2cc; margin:0; max-width:30em;">Enhancing the vibrancy and vitality of Benicia, California — through beautification, local business, military honor, and tourism.</p>
    </div>
    <div>
      <h4 style="font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#b08534; margin:0 0 16px;">Pages</h4>
      <div style="display:flex; flex-direction:column; gap:11px; font-size:14px;">
        <a href={`${base}about/`} style="color:#cdd3e4; text-decoration:none;">About Us</a>
        <a href={`${base}events/`} style="color:#cdd3e4; text-decoration:none;">Events</a>
        <a href={`${base}get-involved/`} style="color:#cdd3e4; text-decoration:none;">Get Involved</a>
        <a href={`${base}newsletter/`} style="color:#cdd3e4; text-decoration:none;">Newsletter</a>
      </div>
    </div>
    <div>
      <h4 style="font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#b08534; margin:0 0 16px;">Connect</h4>
      <div style="display:flex; gap:16px; margin-bottom:18px;">
        <a href={site.instagram_url} target="_blank" rel="noopener" aria-label="Instagram" style="color:#aab2cc;"><svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
        <a href={site.facebook_url} target="_blank" rel="noopener" aria-label="Facebook" style="color:#aab2cc;"><svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
        <a href={site.youtube_url} target="_blank" rel="noopener" aria-label="YouTube" style="color:#aab2cc;"><svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
      </div>
      <a href={site.phone_tel} style="font-size:14px; color:#cdd3e4; text-decoration:none;">{site.phone_display}</a>
    </div>
  </div>
  <div style="border-top:1px solid rgba(255,255,255,0.12); text-align:center; padding:18px; font-size:12px; letter-spacing:0.06em; color:#8b93b0;">&copy; {year} {site.title} &middot; Benicia, California</div>
</footer>
