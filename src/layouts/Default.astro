---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config';

interface Props {
  title?: string;
  description?: string;
  lightbox?: boolean;
}

const { title, description, lightbox = false } = Astro.props;
const pageTitle = title && title !== 'Home' ? `${title} | ${site.title}` : site.title;
const pageDesc = description ?? site.description;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href={`${base}assets/css/site.css`}>
  <link rel="icon" href={`${base}assets/images/logo.png`}>
  {lightbox && <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />}
</head>
<body>
  <div data-site="bab">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </div>
  {lightbox && (
    <Fragment>
      <script is:inline src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
      <script is:inline>GLightbox({ selector: '.glightbox' });</script>
    </Fragment>
  )}
</body>
</html>
