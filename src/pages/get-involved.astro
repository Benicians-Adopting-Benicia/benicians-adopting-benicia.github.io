---
import { getEntry, render } from 'astro:content';
import GetInvolved from '../layouts/GetInvolved.astro';

const entry = await getEntry('pages', 'get-involved');
if (!entry) throw new Error('Missing content entry: pages/get-involved');
const { Content } = await render(entry);
---
<GetInvolved frontmatter={entry.data}><Content /></GetInvolved>
