---
import { getEntry, render } from 'astro:content';
import Default from '../layouts/Default.astro';
import { site } from '../config';

interface Pillar {
  num: string;
  title: string;
  body: string;
}

interface AboutFrontmatter {
  title: string;
  description?: string;
  eyebrow: string;
  subtitle: string;
  hero_image: string;
  hero_alt: string;
  pillars: Pillar[];
}

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing content entry: pages/about');
const { Content } = await render(entry);
const frontmatter = entry.data as AboutFrontmatter;
const base = import.meta.env.BASE_URL;
---
<Default title={frontmatter.title} description={frontmatter.description}>

  <section class="page-header">
    <div class="eyebrow">{frontmatter.eyebrow}</div>
    <h1 data-r="t-page">{frontmatter.title}</h1>
    <p class="lead">{frontmatter.subtitle}</p>
  </section>

  <section class="container container-pad container-1100 about-hero-section">
    <div class="img-frame">
      <img src={`${base}${frontmatter.hero_image.replace(/^\//, '')}`} alt={frontmatter.hero_alt}>
    </div>
  </section>

  <section class="container container-pad container-780 about-mission-section">
    <div class="rule-heading"><h2>Our Mission</h2></div>
    <div class="mission-text">
      <Content />
    </div>
  </section>

  <section class="container container-1100 about-pillars-section">
    <div class="section-divider"><h2>What We Do</h2></div>
    <div class="pillar-grid">
      {frontmatter.pillars.map(pillar => (
        <div>
          <div>{pillar.num}</div>
          <h3>{pillar.title}</h3>
          <p>{pillar.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container container-pad container-1100 about-cta-section">
    <div class="cta-banner">
      <h2>Get in Touch</h2>
      <p>We'd love to hear from you — whether you want to volunteer, partner, or just say hello.</p>
      <div class="btn-group">
        <a href={site.phone_tel} class="btn btn-gold">Call {site.phone_display}</a>
        <a href={`${base}get-involved/`} class="btn btn-ghost-cream">Get Involved &rsaquo;</a>
      </div>
    </div>
  </section>

</Default>
