---
import { getEntry, render } from 'astro:content';
import About, { type AboutFrontmatter } from '../layouts/About.astro';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing content entry: pages/about');
const { Content } = await render(entry);
const frontmatter = entry.data as AboutFrontmatter;
---
<About frontmatter={frontmatter}><Content /></About>
