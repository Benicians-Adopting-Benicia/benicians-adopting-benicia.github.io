---
import { getEntry, render } from 'astro:content';
import Default from '../layouts/Default.astro';
import { site } from '../config';

interface NewsletterFrontmatter {
  title: string;
  description?: string;
  eyebrow: string;
  subtitle: string;
  issue_label: string;
  issue_title: string;
}

const entry = await getEntry('pages', 'newsletter');
if (!entry) throw new Error('Missing content entry: pages/newsletter');
const { Content } = await render(entry);
const frontmatter = entry.data as NewsletterFrontmatter;
---
<Default title={frontmatter.title} description={frontmatter.description}>

  <section class="page-header">
    <div class="eyebrow">{frontmatter.eyebrow}</div>
    <h1 data-r="t-page">{frontmatter.title}</h1>
    <p class="lead">{frontmatter.subtitle}</p>
  </section>

  <section class="container container-pad container-780 newsletter-card-section">
    <div data-r="card-stack" class="card">
      <div>
        <div class="newsletter-icon">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div>
          <div class="eyebrow eyebrow-flush">{frontmatter.issue_label}</div>
          <h2 class="issue-title">{frontmatter.issue_title}</h2>
        </div>
      </div>
      <a href={site.newsletter_url} target="_blank" rel="noopener" class="btn btn-red">Read the Latest Issue</a>
    </div>
  </section>

  <section class="container container-pad container-780 newsletter-content-section">
    <div class="newsletter-prose">
      <Content />
    </div>
  </section>

</Default>
