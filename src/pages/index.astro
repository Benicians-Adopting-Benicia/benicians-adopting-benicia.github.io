---
import Default from '../layouts/Default.astro';
import { site } from '../config';

const base = import.meta.env.BASE_URL;
const galleryImages = Object.keys(
  import.meta.glob('/public/assets/images/gallery/*.png')
).map(p => p.slice('/public'.length));
---
<Default title="Home" description={site.description} lightbox={true}>

<!-- hero -->
<section data-r="g-hero" class="container container-pad container-1180">
  <div>
    <div class="eyebrow">Our Town, Our Pride</div>
    <h2 data-r="t-hero">Keeping the<br><span class="text-accent">spirit</span> of Benicia bright.</h2>
    <p class="hero-lead">A volunteer-driven society devoted to the beauty, business, and civic life of our historic waterfront town — one block, one banner, one neighbor at a time.</p>
    <div class="btn-group">
      <a href={site.donate_url} target="_blank" rel="noopener" class="btn btn-red">Donate Today</a>
      <a href={`${base}get-involved/`} class="btn btn-ghost-navy">Get Involved &rsaquo;</a>
    </div>
  </div>
  <div class="img-frame">
    <div class="hero-frame-inner">
      <img src={`${base}assets/images/gallery/photo-14.png`} alt="Volunteers gathered under the BAB tent">
    </div>
    <div class="hero-caption">Citywide Cleanup Day &middot; Volunteers gather at dawn</div>
  </div>
</section>

<!-- pillars -->
<section class="container container-pad container-1180 pillars-section">
  <div class="section-divider"><h3>The Four Pillars of Our Work</h3></div>
  <div data-r="g4">
    <div data-r="g4cell">
      <svg viewBox="0 0 24 24" fill="none" stroke="#b08534" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
      <div>01</div>
      <h4>Beautification</h4>
      <p>Cleaner streetscapes, tended public spaces, and neighborhoods we're proud to call home.</p>
    </div>
    <div data-r="g4cell">
      <svg viewBox="0 0 24 24" fill="none" stroke="#b08534" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 0 0 3.75-.614A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016 2.993 2.993 0 0 0 2.25-1.016 3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72"/></svg>
      <div>02</div>
      <h4>Local Business</h4>
      <p>Championing the shops and makers that give Benicia its one-of-a-kind character.</p>
    </div>
    <div data-r="g4cell">
      <svg viewBox="0 0 24 24" fill="none" stroke="#b08534" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.5a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/></svg>
      <div>03</div>
      <h4>Military Honor</h4>
      <p>Banners along our streets honoring the service members of our community.</p>
    </div>
    <div data-r="g4cell">
      <svg viewBox="0 0 24 24" fill="none" stroke="#b08534" stroke-width="1.4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
      <div>04</div>
      <h4>Tourism</h4>
      <p>Sharing our waterfront, history, and charm with every visitor who passes through.</p>
    </div>
  </div>
</section>

<!-- quote band -->
<section class="quote-band">
  <div class="container container-780">
    <span class="eyebrow">A Word on Benicia</span>
    <p data-r="t-quote">&ldquo;Once California's state capital, always a town worth tending. We're the neighbors who show up — rake in hand, heart in it.&rdquo;</p>
  </div>
</section>

<!-- video -->
<section class="container container-pad container-900 video-section">
  <div class="section-divider section-divider-tight"><h3>See Our Work</h3></div>
  <div class="img-frame">
    <div class="video-frame">
      <iframe width="100%" height="100%" src="https://www.youtube.com/embed/whgm_vqheDI" title="Benicians Adopting Benicia" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>
  </div>
</section>

<!-- gallery -->
<section class="container container-pad container-1180 gallery-section">
  <div class="gallery-heading-wrap">
    <h3 class="gallery-heading">Our Community in Action</h3>
    <p class="gallery-intro">Scenes from cleanups, banner days, and neighbors at work.</p>
  </div>
  <div data-r="g4 g-gallery">
    {galleryImages.map(img => (
      <a href={`${base}${img.slice(1)}`} class="glightbox gallery-item" data-gallery="community" data-description="Benicians Adopting Benicia">
        <img src={`${base}${img.slice(1)}`} alt="Benicians Adopting Benicia community photo">
      </a>
    ))}
  </div>
</section>

<!-- events CTA -->
<section class="events-cta-band container-pad">
  <div data-r="g-split" class="container container-1180">
    <div data-r="cta-l">
      <div class="eyebrow">Mark Your Calendar</div>
      <h3 class="events-cta-heading">Upcoming Events</h3>
      <p class="events-cta-copy">Join us at our next community gathering — every Benicia resident is welcome, no experience required. Bring a friend.</p>
      <a href={`${base}events/`} class="btn btn-navy">View All Events</a>
    </div>
    <div class="events-cta-img-wrap">
      <img data-r="cta-img" src={`${base}assets/images/gallery/photo-07.png`} alt="">
    </div>
  </div>
</section>

<!-- social -->
<section class="container container-pad container-900 social-section">
  <h3 class="social-heading">Follow Along</h3>
  <p class="social-intro">Stay connected with everything happening in Benicia.</p>
  <div class="social-links">
    <a href={site.instagram_url} target="_blank" rel="noopener" class="link-quiet">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      <span>Instagram</span>
    </a>
    <a href={site.facebook_url} target="_blank" rel="noopener" class="link-quiet">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      <span>Facebook</span>
    </a>
    <a href={site.youtube_url} target="_blank" rel="noopener" class="link-quiet">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      <span>YouTube</span>
    </a>
  </div>
</section>

</Default>
